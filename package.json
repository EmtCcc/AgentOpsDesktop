{
  "name": "agentops-desktop",
  "version": "0.1.0",
  "description": "Desktop application for AgentOps",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "npx playwright test",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:webkit": "npx playwright test --project=webkit",
    "test:e2e:mobile": "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:perf": "npx playwright test performance",
    "test:cross-browser": "npx playwright test cross-browser",
    "test:report": "npx playwright show-report",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir"
  },
  "keywords": [
    "agentops",
    "desktop",
    "electron"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "electron-updater": "^6.3.9",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "electron": "^42.3.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.14.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.agentops.desktop",
    "productName": "AgentOps",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "agentops",
      "repo": "AgentOpsDesktop"
    }
  }
}
