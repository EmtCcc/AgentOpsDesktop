{
  "name": "agentops-desktop",
  "version": "0.1.0",
  "description": "Desktop application for AgentOps",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "npx playwright test",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:webkit": "npx playwright test --project=webkit",
    "test:e2e:mobile": "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:perf": "npx playwright test performance",
    "test:cross-browser": "npx playwright test cross-browser",
    "test:report": "npx playwright show-report",
    "test:smoke": "node scripts/smoke-test.js",
    "test:smoke:api": "node scripts/api-smoke-test.js",
    "test:smoke:deploy": "node scripts/deploy-smoke-test.js",
    "test:smoke:renderer": "npx playwright test smoke",
    "build:bundle": "node scripts/build.js",
    "build": "node scripts/build.js && electron-builder --mac",
    "build:dir": "node scripts/build.js && electron-builder --mac --dir",
    "package": "node scripts/build.js && electron-builder --mac --win --linux",
    "package:mac": "node scripts/build.js && electron-builder --mac",
    "package:win": "node scripts/build.js && electron-builder --win",
    "package:linux": "node scripts/build.js && electron-builder --linux",
    "docs:generate": "node scripts/generate-api-docs.js",
    "check-links": "node scripts/check-links.js"
  },
  "keywords": [
    "agentops",
    "desktop",
    "electron"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.3.9",
    "hono": "^4.12.23",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.0.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "electron": "^41.7.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "eslint": "^9.14.0",
    "prettier": "^3.8.3",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.agentops.desktop",
    "productName": "AgentOps",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "agentops",
      "repo": "AgentOpsDesktop"
    }
  }
}
