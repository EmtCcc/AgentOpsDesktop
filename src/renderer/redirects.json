{
  "_meta": {
    "version": 2,
    "description": "URL redirect map — AgentOps Desktop renderer",
    "categories": {
      "redirect": "301 — old path maps to canonical path",
      "gone": "410 — page intentionally removed, no replacement"
    }
  },

  "redirects": {
    "/home": "/",
    "/overview": "/",
    "/dashboard": "/",

    "/agent": "/agents",
    "/workers": "/agents",
    "/agent/:agentId": "/agents/:agentId",
    "/workers/:agentId": "/agents/:agentId",
    "/agents/:agentId/details": "/agents/:agentId",
    "/agents/:agentId/config": "/agents/:agentId",
    "/agents/:agentId/logs": "/agents/:agentId",

    "/task": "/tasks",
    "/issues": "/tasks",
    "/work": "/tasks",
    "/task/:taskId": "/tasks/:taskId",
    "/issues/:taskId": "/tasks/:taskId",
    "/tasks/:taskId/details": "/tasks/:taskId",
    "/tasks/:taskId/logs": "/tasks/:taskId",

    "/log": "/logs",
    "/terminal": "/logs",
    "/console": "/logs",
    "/output": "/logs",
    "/logs/:agentId": "/logs?agent=:agentId",

    "/config": "/settings",
    "/preferences": "/settings",
    "/settings/general": "/settings",
    "/settings/agent-config": "/settings/agents",
    "/settings/approvals": "/settings/governance",
    "/settings/policies": "/settings/governance",
    "/settings/api-keys": "/settings",
    "/settings/notifications": "/settings",

    "/workflow": "/workflows",
    "/pipelines": "/workflows",
    "/pipeline": "/workflows",
    "/workflow/:workflowId": "/workflows/:workflowId",
    "/pipelines/:workflowId": "/workflows/:workflowId",
    "/workflows/:workflowId/run": "/workflows/:workflowId",
    "/workflows/:workflowId/edit": "/workflows/:workflowId"
  },

  "gone": [
    "/beta",
    "/invite",
    "/onboarding",
    "/setup-wizard",
    "/legacy-dashboard",
    "/admin",
    "/admin/users",
    "/admin/billing",
    "/marketplace",
    "/plugins",
    "/integrations/legacy",
    "/docs/internal",
    "/debug",
    "/debug/state",
    "/debug/ipc",
    "/experimental",
    "/experimental/copilot",
    "/experimental/auto-pilot"
  ]
}
